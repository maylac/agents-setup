{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "'$HOME/.codex/hooks/rtk-rewrite.sh'"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash '$HOME/.codex/herdr-agent-state.sh' session",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "'$HOME/.agents/skills/agmsg/scripts/session-start.sh' codex '$HOME'",
            "timeout": 10
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "'$HOME/.agents/hooks/notify-mobile.sh' approval Codex"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "'$HOME/.codex/hooks/agent-terminal-notify.sh' Codex"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.codex/runcat-hook.py",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "'$HOME/.agents/hooks/notify-mobile.sh' done Codex"
          }
        ]
      }
    ]
  }
}
