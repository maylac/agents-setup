{
  "language": "Japanese",
  "theme": "dark-daltonized",
  "includeCoAuthoredBy": false,
  "remoteControlAtStartup": true,
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Bash(ls *)",
      "Bash(rg *)",
      "Bash(command -v *)",
      "Bash(which *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git rev-parse *)",
      "Bash(git branch --show-current *)",
      "Bash(git worktree list *)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(git -C * push *)",
      "Bash(gh pr create *)",
      "Bash(gh release *)",
      "Bash(brew install *)",
      "Bash(brew uninstall *)",
      "Bash(npm publish *)",
      "Bash(pnpm publish *)",
      "Bash(yarn publish *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(curl *)",
      "Bash(sudo *)",
      "Read(**/.env)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git push --force-with-lease *)",
      "Bash(git -C * push --force *)",
      "Bash(git -C * push -f *)",
      "Bash(git -C * push --force-with-lease *)",
      "Bash(git reset --hard *)",
      "Bash(git -C * reset --hard *)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$HOME/.claude/statusline.py"
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/agent-terminal-notify.sh Claude"
          }
        ]
      }
    ],
    "Elicitation": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Ping.aiff 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Submarine.aiff 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/compaction-recovery.py"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/compaction-recovery.py"
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/instructions-loaded-audit.py",
            "async": true
          }
        ]
      }
    ]
  },
  "outputStyle": "Maylac Operator",
  "enabledPlugins": {
    "codex@openai-codex": true,
    "clangd-lsp@claude-plugins-official": true,
    "andrej-karpathy-skills@karpathy-skills": false,
    "frontend-design@claude-plugins-official": true,
    "superpowers@superpowers-marketplace": true,
    "pyright-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "kotlin-lsp@claude-plugins-official": true,
    "aws-core@claude-plugins-official": false,
    "project-artifact@claude-plugins-official": false
  }
}
